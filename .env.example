# ─── Supabase ───
# Project URL and anon key from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic (Claude API) ───
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Model id — see src/lib/anthropic.ts. Spec calls for claude-sonnet-4-20250514;
# we default to the latest Sonnet (claude-sonnet-4-6) for better quality + cost.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Resend (email send + inbound) ───
# https://resend.com/api-keys
RESEND_API_KEY=
# Webhook signing secret — https://resend.com/webhooks
RESEND_WEBHOOK_SECRET=
# Default From: address — must be a verified domain in Resend
RESEND_FROM_EMAIL=hello@aylek.sales

# ─── Stripe ───
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Apollo.io (Prospect-01 — primary provider) ───
# https://app.apollo.io/ → Settings → Integrations → API
# Industry/title-driven prospecting. Free plan: 50 exports / month.
# Basic plan: 10,000 / month. The search endpoint requires Basic+.
APOLLO_API_KEY=
# Optional: override the API base URL (defaults to https://api.apollo.io)
# APOLLO_BASE_URL=https://api.apollo.io

# ─── Hunter.io (Prospect-01 — fallback provider) ───
# https://hunter.io/api-keys
# Domain-driven prospecting. Used as a fallback when Apollo returns
# 403 / 429 / 5xx, or as the sole provider when APOLLO_API_KEY isn't set.
# Requires `icp.target_domains` on the playbook (Hunter needs domains to
# search, not industries). Free plan: 25 searches / month.
HUNTER_API_KEY=
# Optional: override the API base URL (defaults to https://api.hunter.io)
# HUNTER_BASE_URL=https://api.hunter.io

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Random string used to authorise cron + agent routes. Generate with:
#   openssl rand -hex 32
CRON_SECRET=
